    </section>

    <!-- Gallery -->
    <section class="section section-card" id="gallery">
      <h2 class="section-title">Gallery</h2>
      <div class="gallery-grid observe fade-up">
        <img src="/images/gallery-1.jpg" alt="Classroom photo 1" />
        <img src="/images/gallery-2.jpg" alt="Classroom photo 2" />
        <img src="/images/gallery-3.jpg" alt="Students studying" />
        <img src="/images/gallery-4.jpg" alt="Award function" />
        <img src="/images/gallery-6.jpg" alt="Teacher explaining" />
      </div>
    </section>

    <!-- Location -->
    <section class="section" id="location">
      <h2 class="section-title">Location</h2>
      <p class="section-subtitle">
        #553, Kanshi Nagar, Model Town, Near Jaspal Nursing Home, Opp. DAV Public School, Ambala City
      </p>
      <div class="location-wrapper observe slide-up">
        <div class="map-container">
          <iframe
            title="Maths Tuition by Vimmy Ma'am – Location"
            src="https://maps.google.com/maps?q=D.A.V+Public+School+Kanshi+Nagar+Model+Town+Ambala+City+Haryana&z=16&output=embed"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade">
          </iframe>
        </div>
        <div class="location-actions">
          <p class="address">
            #553, Kanshi Nagar, Model Town<br />
            Near Jaspal Nursing Home<br />
            Opp. DAV Public School<br />
            Ambala City – 134003
          </p>
          <div class="location-buttons">
            <a href="tel:+917838398494" class="btn btn-primary ripple btn-small">Call Now</a>
            <a href="https://maps.app.goo.gl/5izSBtYAxTQuoSH8A"
              class="btn btn-outline ripple btn-small"
              target="_blank"
              rel="noopener">
              Get Directions
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section class="section section-card" id="contact">
      <h2 class="section-title">Contact & Enquiry</h2>

      <% if (successMessage) { %>
        <div class="alert alert-success" id="contact-alert"><%= successMessage %></div>
      <% } %>
      <% if (errorMessage) { %>
        <div class="alert alert-error" id="contact-alert"><%= errorMessage %></div>
      <% } %>

      <form class="contact-form observe fade-up" method="POST" action="/contact" novalidate>
        <div class="form-row">
          <div class="form-group">
            <label for="name">Student / Parent Name *</label>
            <input type="text" id="name" name="name" required minlength="2" />
          </div>
          <div class="form-group">
            <label for="phone">Phone Number *</label>
            <input type="tel" id="phone" name="phone" required pattern="[0-9]{10,}" />
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="studentClass">Class *</label>
            <select id="studentClass" name="studentClass" required>
              <option value="">Select Class</option>
              <option value="10">Class 10</option>
              <option value="11">Class 11</option>
              <option value="12">Class 12</option>
            </select>
          </div>
          <div class="form-group">
            <label for="mode">Preferred Mode *</label>
            <select id="mode" name="mode" required>
              <option value="">Select Mode</option>
              <option value="Offline">Offline</option>
              <option value="Online">Online</option>
            </select>
          </div>
        </div>
        <div class="form-group form-group-full">
          <label for="message">Message / Query *</label>
          <textarea id="message" name="message" rows="4" required
            placeholder="Share preferred batch timing or any questions..."></textarea>
        </div>
        <button type="submit" class="btn btn-primary ripple form-submit btn-narrow">Submit Enquiry</button>
      </form>
    </section>

  </main>

  <!-- Fixed bottom mobile bar -->
  <div class="mobile-bar">
    <a href="tel:+917838398494" class="mobile-bar-btn">Call Now</a>
    <a href="<%= waLink %>" class="mobile-bar-btn mobile-bar-btn--whatsapp" target="_blank" rel="noopener">
      WhatsApp
    </a>
  </div>

  <script src="/js/main.js"></script>

  <!-- Footer -->

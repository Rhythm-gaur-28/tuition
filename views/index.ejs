<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle %></title>
  <meta name="description"
    content="Maths Tuition by Vimmy Ma'am – CBSE coaching for Classes 10, 11 & 12 in Ambala City, Haryana. Online and offline batches available." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Merriweather:wght@600;700&family=Poppins:wght@300;400;500;600&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="/css/styles.css" />
</head>

<body>

  <header class="header js-header">
    <div class="header-inner">
      <div class="logo">
        <img src="/images/logo-2.png" alt="Maths Tuition Logo" />
        <div class="logo-text">
          <span class="logo-title">Maths Tuition</span>
          <span class="logo-subtitle">by Vimmy Ma'am</span>
        </div>
      </div>
      <button class="hamburger js-hamburger" aria-label="Toggle navigation">
        <span></span>
        <span></span>
        <span></span>
      </button>
      <nav class="nav js-nav">
        <a href="#why">Why Us</a>
        <a href="#subjects">Subjects</a>
        <a href="#classes">Classes</a>
        <a href="#about">Tutor</a>
        <a href="#timings">Timings</a>
        <a href="#contact">Contact</a>
      </nav>
    </div>
  </header>

  <main>

    <!-- Hero -->
    <section class="hero section" id="home">
      <div class="hero-bg-shape hero-bg-shape--1"></div>
      <div class="hero-bg-shape hero-bg-shape--2"></div>
      <div class="hero-bg-shape hero-bg-shape--3"></div>
      <div class="hero-content animate-on-load">
        <p class="hero-kicker">Expert CBSE Maths Coaching in Ambala</p>
        <h1 class="hero-heading">Maths Tuition for Classes 10, 11 & 12</h1>
        <p class="hero-subheading">
          Online & Offline Batches | Personal Attention | 15+ Years Experience
        </p>
        <div class="hero-buttons">
          <a href="#contact" class="btn btn-primary ripple">Enroll Now</a>
          <a href="<%= waLink %>" class="btn btn-whatsapp ripple" target="_blank" rel="noopener">
            Chat on WhatsApp
          </a>
        </div>
        <ul class="hero-highlights">
          <li>M.Sc. Mathematics | HTET TGT & PGT Qualified</li>
          <li>DAV PGT CBT Qualified</li>
          <li>Located in Model Town, Ambala City</li>
        </ul>
      </div>
    </section>

    <!-- Why Choose Us -->
    <section class="section section-card" id="why">
      <h2 class="section-title">Why Choose Us</h2>
      <p class="section-subtitle">
        A focused learning environment that supports every student.
      </p>
      <div class="why-grid">
        <article class="info-card observe fade-up">
          <div class="info-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
              stroke-linejoin="round">
              <circle cx="7" cy="9" r="3" />
              <circle cx="17" cy="9" r="3" />
              <path d="M2 20c0-3 2.5-5 5-5s5 2 5 5" />
              <path d="M12 20c0-3 2.5-5 5-5s5 2 5 5" />
            </svg>
          </div>
          <h3>Small Batch Size</h3>
          <p>Limited seats in each batch to ensure every student gets personal attention.</p>
        </article>

        <article class="info-card observe fade-up">
          <div class="info-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
              stroke-linejoin="round">
              <circle cx="10.5" cy="10.5" r="8" />
              <path d="M21 21l-4.5-4.5" />
              <circle cx="10.5" cy="8.5" r="2.3" />
              <path d="M7.5 16c0-2.4 1.8-3.5 3-3.5s3 1.1 3 3.5" />
            </svg>
          </div>
          <h3>Individual Attention</h3>
          <p>Mentor-style guidance with regular one‑to‑one doubt clearing sessions.</p>
        </article>

        <article class="info-card observe fade-up">
          <div class="info-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
              stroke-linejoin="round">
              <rect x="5" y="3" width="14" height="18" rx="2"></rect>
              <path d="M8 8h8M8 12h5M9 16l1.5 1.5L13 15" />
            </svg>
          </div>
          <h3>Weekly Assessments</h3>
          <p>Structured tests with detailed feedback to track student progress regularly.</p>
        </article>

        <article class="info-card observe fade-up">
          <div class="info-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"
              stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2" />
              <path d="M8 21h8M12 17v4" />
              <circle cx="12" cy="10" r="3" />
            </svg>
          </div>
          <h3>Online & Offline</h3>
          <p>Flexible mode — attend from home or in person, whichever suits you best.</p>
        </article>
      </div>
    </section>

    <!-- Subjects Offered -->
    <section class="section" id="subjects">
      <h2 class="section-title">Subject Offered</h2>
      <p class="section-subtitle">Specialized CBSE Mathematics coaching for senior classes.</p>
      <div class="subjects-grid single-subject">
        <div class="subject-card observe stagger">
          <div class="subject-svg">
            <svg viewBox="0 0 24 24" width="80" height="80" fill="none" stroke="currentColor" stroke-width="1.6"
              stroke-linecap="round">
              <path d="M6 6v6M3 9h6" />
              <path d="M13 9h6" />
              <path d="M4 17l4 4M8 17l-4 4" />
              <circle cx="16" cy="16.5" r="1" />
              <circle cx="16" cy="21" r="1" />
              <path d="M13 18.75h6" />
            </svg>
          </div>
          <h3>Mathematics</h3>
        </div>
      </div>
    </section>

    <!-- Classes We Teach (Accordion) -->
    <section class="section section-card" id="classes">
      <h2 class="section-title">Classes We Teach</h2>
      <div class="classes-intro">
        Focused batches for board exam preparation and senior secondary Mathematics.
      </div>
      <div class="accordion">

        <div class="accordion-item observe slide-up">
          <button class="accordion-header js-accordion-header">
            <div class="accordion-header-main">
              <span class="badge badge-accent">10</span>
              <span>Class 10 – Board Foundation</span>
            </div>
            <span class="accordion-icon">+</span>
          </button>
          <div class="accordion-body">
            <ul class="accordion-list">
              <li>NCERT line‑by‑line coverage with exemplar problems.</li>
              <li>Chapter‑wise test series and revision worksheets.</li>
              <li>Detailed discussion of previous year board questions.</li>
            </ul>
          </div>
        </div>

        <div class="accordion-item observe slide-up">
          <button class="accordion-header js-accordion-header">
            <div class="accordion-header-main">
              <span class="badge badge-secondary">11</span>
              <span>Class 11 – Senior Secondary</span>
            </div>
            <span class="accordion-icon">+</span>
          </button>
          <div class="accordion-body">
            <ul class="accordion-list">
              <li>Strong conceptual foundation for Class 11 CBSE Maths.</li>
              <li>Focus on algebra, calculus, trigonometry and coordinate geometry.</li>
              <li>Regular practice sheets and doubt clearing sessions.</li>
            </ul>
          </div>
        </div>

        <div class="accordion-item observe slide-up">
          <button class="accordion-header js-accordion-header">
            <div class="accordion-header-main">
              <span class="badge badge-primary">12</span>
              <span>Class 12 – Board Preparation</span>
            </div>
            <span class="accordion-icon">+</span>
          </button>
          <div class="accordion-body">
            <ul class="accordion-list">
              <li>Complete CBSE Class 12 Maths syllabus coverage.</li>
              <li>Focus on derivations, numericals and step-marking technique.</li>
              <li>Pre-board mock tests and exam strategy sessions.</li>
            </ul>
          </div>
        </div>

      </div>
    </section>

    <!-- About Tutor -->
    <section class="section" id="about">
      <h2 class="section-title">About the Tutor</h2>
      <div class="about-wrapper observe slide-left">
        <div class="about-image about-image-large">
          <img src="/images/tutor-2.jpg" alt="Vimmy Ma'am – Maths Tutor" />
        </div>
        <div class="about-content about-content-wide">
          <h3>Vimmy Ma'am</h3>
          <p class="about-short">
            M.Sc. (Mathematics) · HTET TGT & PGT Qualified · DAV PGT CBT Qualified · 15+ years of CBSE teaching experience.
          </p>
          <p class="about-paragraph">
            With over 15 years of experience teaching CBSE Mathematics, Vimmy Ma'am brings clarity, patience and
            a structured approach to every class. Her teaching focuses on building strong conceptual understanding
            first, followed by graded practice to develop speed and accuracy. Students preparing for Class 10, 11
            and 12 boards consistently achieve improved results under her guidance. Both online and offline
            batches are available to suit every student's schedule.
          </p>
        </div>
      </div>
    </section>

    <!-- Benefits -->
    <section class="section section-card section-benefits" id="benefits">
      <h2 class="section-title">Benefits for Students</h2>
      <p class="section-subtitle">
        A complete support system that keeps students motivated and on track.
      </p>
      <div class="benefits-grid observe fade-up">
        <article class="benefit-card">
          <div class="benefit-icon-circle">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"
              stroke-linejoin="round">
              <rect x="4" y="4" width="16" height="16" rx="2" />
              <path d="M7 9h10M7 13h6" />
            </svg>
          </div>
          <h3>Regular Tests</h3>
          <p>Topic‑wise tests with timely feedback and corrections.</p>
        </article>
        <article class="benefit-card">
          <div class="benefit-icon-circle">
            <svg viewBox="0 0 32 32" width="64" height="64" fill="none" stroke="currentColor" stroke-width="1.7"
              stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 3a8 8 0 0 1 5.66 13.66C20.5 18 20 19.5 20 21H12c0-1.5-.5-3-1.66-4.34A8 8 0 0 1 16 3z" />
              <path d="M12 23h8" />
              <path d="M13.5 26h5" />
              <path d="M14 10.5c0-2 4-2 4 0c0 1.5-2 1.8-2 3.2" />
              <circle cx="16" cy="16" r="0.7" fill="currentColor" stroke="none" />
            </svg>
          </div>
          <h3>Doubt Support</h3>
          <p>Dedicated time for doubts after class and on WhatsApp.</p>
        </article>
        <article class="benefit-card">
          <div class="benefit-icon-circle">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"
              stroke-linejoin="round">
              <circle cx="8" cy="9" r="2.2" />
              <circle cx="16" cy="9" r="2.2" />
              <path d="M4 18c0-2.2 1.8-4 4-4" />
              <path d="M12 18c0-2.2 1.8-4 4-4" />
            </svg>
          </div>
          <h3>Parent Meetings</h3>
          <p>Periodic discussions to review performance and plan ahead.</p>
        </article>
        <article class="benefit-card">
          <div class="benefit-icon-circle">
            <svg viewBox="0 0 32 32" width="64" height="64" fill="none" stroke="currentColor" stroke-width="1.7"
              stroke-linecap="round" stroke-linejoin="round">
              <circle cx="16" cy="16" r="13" />
              <circle cx="16" cy="16" r="6.5" />
              <line x1="28" y1="9" x2="14" y2="18" />
              <line x1="14" y1="18" x2="15.5" y2="13.3" />
              <line x1="14" y1="18" x2="18.3" y2="18.2" />
            </svg>
          </div>
          <h3>Exam Strategy</h3>
          <p>Board paper tips, step-marking technique and mock test practice.</p>
        </article>
      </div>
    </section>

    <!-- Batch Timings -->
    <section class="section section-card" id="timings">
      <h2 class="section-title">Batch Timings</h2>
      <div class="timings-table-wrapper observe slide-right">
        <table class="timings-table">
          <thead>
            <tr>
              <th>Batch</th>
              <th>Classes</th>
              <th>Days</th>
              <th>Time</th>
              <th>Mode</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Morning Batch</td>
              <td>10, 11 & 12</td>
              <td>Mon – Sat</td>
              <td>6:00 AM – 2:00 PM</td>
              <td>Online & Offline</td>
            </tr>
            <tr>
              <td>Evening Batch</td>
              <td>10, 11 & 12</td>
              <td>Mon – Sat</td>
              <td>3:00 PM – 8:30 PM</td>
              <td>Online & Offline</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="section" id="testimonials">
      <h2 class="section-title">Testimonials</h2>
      <div class="testimonials-wrapper">
        <div class="testimonials-track">

          <article class="testimonial-card">
            <div class="testimonial-top">
              <div class="testimonial-avatar">
                <img src="https://i.pinimg.com/736x/21/07/77/210777f717fa0a802f3b693ffe98c502.jpg" alt="Parent testimonial" />
              </div>
              <div>
